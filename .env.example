# Copy this file to .env and fill in real values.
# NEVER commit .env to the repository.

# ---------- LLM ----------
# DeepSeek API key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- Embedding ----------
# 默认走本地模型目录（首次使用前先跑 scripts/download_models.sh 拉到这里）。
# 若想直接用 HuggingFace cache，改成 EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5。
EMBEDDING_MODEL=data/models/bge-large-zh-v1.5

# ---------- Storage ----------
# SQLite database URL (relative paths resolved from backend/)
DATABASE_URL=sqlite:///./data/app.db

# Chroma persistence directory
CHROMA_PERSIST_DIR=./data/chroma

# ---------- RAG Chat ----------
# Default false keeps the backend bootable without rag extras or a local Chroma index.
RAG_ENABLED=false
RAG_CHROMA_DIR=./var/chroma
RAG_COLLECTION=papers
CHAT_TOP_K=5
CHAT_MAX_CONTEXT_CHARS=4000
CHAT_TEMPERATURE=0.3

# ---------- RAG Reranker (M1.4-b) ----------
# 二阶段检索：embedding 召回 top_k_recall → reranker 重排取 top_n。
# 关闭时纯 embedding 路径，行为与 M1.3.x 完全一致。
# 模型 ~2.2 GB，启用前先跑 scripts/download_models.sh reranker。
RAG_RERANKER_ENABLED=false
RAG_RERANKER_TOP_K_RECALL=20
RAG_RERANKER_TOP_N=5
RAG_RERANKER_MODEL=data/models/bge-reranker-v2-m3

# ---------- App ----------
APP_ENV=development
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000
